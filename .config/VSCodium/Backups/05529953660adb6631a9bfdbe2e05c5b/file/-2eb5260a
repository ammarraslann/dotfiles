    "# ============================================================\n",
    "#  CELL 1 — Imports & config\n",
    "# ============================================================\n",
    "import subprocess\n",
    "import numpy as np\n",
    "import h5py\n",
    "import os\n",
    "from pathlib import Path\n",
    "from tqdm.notebook import tqdm\n",
    "\n",
    "# ── EDIT THESE ──────────────────────────────────────────────\n",
    "AVI_PATH     = r\"/mnt/Transcend/vlab/260406_Plate4_ctrldistance_N2/video-04062026171016-0000.avi\"\n",
    "OUT_DIR      = r\"/mnt/Transcend/vlab/260406_Plate4_ctrldistance_N2/PREVIEW\"\n",
    "FRAME_STRIDE = 10      # keep every Nth frame\n",
    "GRAYSCALE    = True    # True = store as grayscale, False = store as BGR color\n",
    "# ────────────────────────────────────────────────────────────\n",
    "\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "# Get video metadata via ffprobe\n",
    "probe = subprocess.run([\n",
    "    \"ffprobe\", \"-v\", \"error\",\n",
    "    \"-select_streams\", \"v:0\",\n",
    "    \"-show_entries\", \"stream=width,height,r_frame_rate,nb_frames\",\n",
    "    \"-of\", \"csv=p=0\",\n",
    "    AVI_PATH\n",
    "], capture_output=True, text=True)\n",
    "\n",
    "vals              = probe.stdout.strip().split(\",\")\n",
    "width, height     = int(vals[0]), int(vals[1])\n",
    "fps_num, fps_den  = map(int, vals[2].split(\"/\"))\n",
    "fps_orig          = fps_num / fps_den\n",
    "total_frames      = int(vals[3])\n",
    "kept_frames       = total_frames // FRAME_STRIDE\n",
    "\n",
    "print(f\"Source      : {Path(AVI_PATH).name}\")\n",
    "print(f\"Resolution  : {width} × {height}\")\n",
    "print(f\"FPS         : {fps_orig:.3f}\")\n",
    "print(f\"Total frames: {total_frames}\")\n",
    "print(f\"Stride      : every {FRAME_STRIDE}th frame → {kept_frames} frames stored\")\n",
    "print(f\"Grayscale   : {GRAYSCALE}\")\n",
    "\n",
    "channels   = 1 if GRAYSCALE else 3\n",
    "pix_fmt    = \"gray\" if GRAYSCALE else \"bgr24\"\n",
    "frame_bytes = width * height * channels\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "#  CELL 2 — Stream AVI via ffmpeg and write directly to H5\n",
    "# ============================================================\n",
    "out_fps  = fps_orig / FRAME_STRIDE\n",
    "stem     = Path(AVI_PATH).stem\n",
    "h5_path  = os.path.join(OUT_DIR, f\"{stem}.h5\")\n",
    "\n",
    "cmd = [\n",
    "    \"ffmpeg\", \"-i\", AVI_PATH,\n",
    "    \"-vf\", f\"select='not(mod(n\\\\,{FRAME_STRIDE}))'\",  # keep every Nth frame\n",
    "    \"-vsync\", \"vfr\",\n",
    "    \"-f\", \"rawvideo\",\n",
    "    \"-pix_fmt\", pix_fmt,\n",
    "    \"-\"\n",
    "]\n",
    "\n",
    "print(f\"\\nConverting to H5: {h5_path}\")\n",
    "proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)\n",
    "\n",
    "with h5py.File(h5_path, 'w') as f:\n",
    "\n",
    "    # Create resizable dataset — we don't know exact frame count until done\n",
    "    if GRAYSCALE:\n",
    "        ds = f.create_dataset(\n",
    "            \"data\",\n",
    "            shape=(0, height, width),\n",
    "            maxshape=(None, height, width),\n",
    "            dtype=np.uint8,\n",
    "            chunks=(1, height, width),   # one frame per chunk for fast random access\n",
    "            compression=\"gzip\",\n",
    "            compression_opts=1           # light compression — fast write, decent size\n",
    "        )\n",
    "    else:\n",
    "        ds = f.create_dataset(\n",
    "            \"data\",\n",
    "            shape=(0, height, width, 3),\n",
    "            maxshape=(None, height, width, 3),\n",
    "            dtype=np.uint8,\n",
    "            chunks=(1, height, width, 3),\n",
    "            compression=\"gzip\",\n",
    "            compression_opts=1\n",
    "        )\n",
    "\n",
    "    # Metadata datasets\n",
    "    frame_indices = []\n",
    "    times         = []\n",
    "    fi            = 0   # kept frame counter\n",
    "    orig_fn       = 0   # original frame counter\n",
    "\n",
    "    with tqdm(total=kept_frames) as pbar:\n",
    "        while True:\n",
    "            raw = proc.stdout.read(frame_bytes)\n",
    "            if len(raw) < frame_bytes:\n",
    "                break\n",
    "\n",
    "            if GRAYSCALE:\n",
    "                frame = np.frombuffer(raw, dtype=np.uint8).reshape((height, width))\n",
    "            else:\n",
    "                frame = np.frombuffer(raw, dtype=np.uint8).reshape((height, width, 3))\n",
    "\n",
    "            # Append frame to resizable dataset\n",
    "            ds.resize(fi + 1, axis=0)\n",
    "            ds[fi] = frame\n",
    "\n",
    "            frame_indices.append(orig_fn * FRAME_STRIDE)\n",
    "            times.append((orig_fn * FRAME_STRIDE) / fps_orig)\n",
    "\n",
    "            fi      += 1\n",
    "            orig_fn += 1\n",
    "            pbar.update(1)\n",
    "\n",
    "    # Write metadata\n",
    "    f.create_dataset(\"frame_indices\", data=np.array(frame_indices, dtype=np.int64))\n",
    "    f.create_dataset(\"times\",         data=np.array(times,         dtype=np.float64))\n",
    "    f.attrs[\"fps_original\"] = fps_orig\n",
    "    f.attrs[\"fps_stored\"]   = out_fps\n",
    "    f.attrs[\"frame_stride\"] = FRAME_STRIDE\n",
    "    f.attrs[\"source_file\"]  = str(AVI_PATH)\n",
    "\n",
    "proc.stdout.close()\n",
    "proc.wait()\n",
    "\n",
    "print(f\"\\nDone.\")\n",
    "print(f\"  Frames written : {fi}\")\n",
    "print(f\"  H5 file size   : {os.path.getsize(h5_path) / 1e9:.2f} GB\")\n",
    "print(f\"  H5 path        : {h5_path}\")\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "#  CELL 3 — Verify: read back a frame and display it\n",
    "# ============================================================\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "with h5py.File(h5_path, 'r') as f:\n",
    "    print(\"Keys       :\", list(f.keys()))\n",
    "    print(\"data shape :\", f['data'].shape)\n",
    "    print(\"times shape:\", f['times'].shape)\n",
    "    print(\"Attrs      :\", dict(f.attrs))\n",
    "\n",
    "    # Show first, middle, and last frame\n",
    "    n = f['data'].shape[0]\n",
    "    fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "    for ax, idx, label in zip(axes, [0, n//2, n-1], [\"First\", \"Middle\", \"Last\"]):\n",
    "        frame = f['data'][idx]\n",
    "        ax.imshow(frame, cmap='gray' if GRAYSCALE else None)\n",
    "        ax.set_title(f\"{label} (frame {idx})\")\n",
    "        ax.axis('off')\n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
